{
  "name": "nexusos-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "install-frontend": "npm install --prefix frontend",
    "start-backend": "python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000 --app-dir backend",
    "start-frontend": "npm run dev --prefix frontend -- --host 0.0.0.0 --port 3000",
    "start": "npm run install-frontend && concurrently \"npm run start-backend\" \"npm run start-frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
